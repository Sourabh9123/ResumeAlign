FASTAPI_ENV=development
PROJECT_NAME="AI Resume Builder & JD Optimizer"
VERSION=1.0.0
API_V1_STR=/api/v1
SECRET_KEY=generate_a_secure_random_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
DOCS_USERNAME=admin
DOCS_PASSWORD=admin

POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=resume_builder
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

REDIS_URL=redis://redis:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LLM_REQUESTS=10
RATE_LIMIT_LLM_WINDOW_SECONDS=3600
RATE_LIMIT_GENERAL_REQUESTS=120
RATE_LIMIT_GENERAL_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=300
CACHE_ENABLED=true
CACHE_LLM_TTL_SECONDS=86400

# AI Providers
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key
DEFAULT_AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_LATEX_MODEL=gpt-4.1-mini
ANTHROPIC_MODEL=claude-3-haiku-20240307
XPDF_PDFTOTEXT_BINARY=pdftotext
XPDF_PDFTOTEXT_TIMEOUT_SECONDS=30
JD_URL_FETCH_TIMEOUT_SECONDS=12
JD_URL_MAX_CHARS=30000
JD_URL_MIN_TEXT_CHARS=250

# AWS S3 Settings
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_private_s3_bucket
